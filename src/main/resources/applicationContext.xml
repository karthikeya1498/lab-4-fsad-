<?xml version="1.0" encoding="UTF-8"?>

<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- Student Bean -->
    <bean id="student" class="klh.edu.in.lab4.Student">

        <!-- Constructor Injection -->
        <constructor-arg value="403"/>
        <constructor-arg value="KARTHIKEYA"/>
        <constructor-arg value="Advanced Spring"/>
        <constructor-arg value="2026"/>

        <!-- Setter Injection -->
        <property name="course" value="Advanced Spring"/>
        <property name="year" value="2025"/>

    </bean>

</beans>